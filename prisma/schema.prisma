generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Product {
  id             String   @id @default(cuid())
  name           String
  nameEn         String?  @map("name_en")
  price          Int?
  description    String
  descriptionEn  String?  @map("description_en")
  image          String
  category       String
  subcategory    String?
  media          String[]
  createdAt      DateTime @default(now())
}
